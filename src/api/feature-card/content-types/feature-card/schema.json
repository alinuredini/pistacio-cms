{
  "kind": "collectionType",
  "collectionName": "feature_cards",
  "info": {
    "singularName": "feature-card",
    "pluralName": "feature-cards",
    "displayName": "Feature card"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
    "slug": {
      "type": "uid",
      "required": true,
      "targetField": "title"
    },
    "title": {
      "type": "string",
      "required": true,
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "body": {
      "type": "text",
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "iconKey": {
      "type": "string"
    },
    "tone": {
      "type": "enumeration",
      "enum": ["mint", "soft", "cool", "rose", "white", "ink"],
      "default": "mint"
    },
    "page": {
      "type": "string",
      "default": "home"
    },
    "order": {
      "type": "integer",
      "default": 0
    }
  }
}
