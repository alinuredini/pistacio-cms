{
  "kind": "collectionType",
  "collectionName": "nav_items",
  "info": {
    "singularName": "nav-item",
    "pluralName": "nav-items",
    "displayName": "Nav item"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
    "label": {
      "type": "string",
      "required": true,
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "href": {
      "type": "string",
      "required": true
    },
    "order": {
      "type": "integer",
      "default": 0
    },
    "external": {
      "type": "boolean",
      "default": false
    }
  }
}
