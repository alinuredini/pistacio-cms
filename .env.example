# Strapi env example
HOST=0.0.0.0
PORT=1337

# Generate strong values: `node -e "console.log(crypto.randomBytes(16).toString('base64'))"`
APP_KEYS=replace_with_two_or_more_comma_separated_random_strings
API_TOKEN_SALT=replace_with_random_base64
JWT_SECRET=replace_with_random_base64
ADMIN_JWT_SECRET=replace_with_random_base64
TRANSFER_TOKEN_SALT=replace_with_random_base64

# Database — leave DATABASE_CLIENT unset locally to use SQLite (default).
# DATABASE_CLIENT=postgres
# DATABASE_URL=postgres://pistacio:pistacio@localhost:5432/pistacio_cms
# DATABASE_SSL=false

# Public URL (used by webhooks + admin)
PUBLIC_URL=http://localhost:1337

# i18n
CMS_DEFAULT_LOCALE=en
CMS_LOCALES=en,de
